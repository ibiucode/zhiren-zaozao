# 職人自造 backend 環境變數範例（複製為 .env 後填值；.env 不應提交）

# 環境：development | production。production 時若仍用預設密鑰/密碼會拒絕啟動。
ENVIRONMENT=development

# 資料庫連線。正式環境 / Render 使用 PostgreSQL：
# （Render 提供的 postgres://... 會自動正規化為 SQLAlchemy 的 driver 形式）
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@localhost:5432/zhiren_zaozao

# 本機若沒有 PostgreSQL，可改用 SQLite（免安裝，立即可跑）：
# DATABASE_URL=sqlite:///./dev.db
# 註：未設定 DATABASE_URL 時，程式預設即為 sqlite:///./dev.db。

# 允許的前端來源（CORS），逗號分隔。
# 本機開發：前台 Vite (5173/4173) 與 admin 後台 (5174/4174)。正式再加上實際網址。
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:5174,http://localhost:4174

# --- Admin / Auth（Phase 3）---
# JWT 簽章密鑰：正式環境務必改成隨機長字串（例如 `openssl rand -hex 32`）。
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=720

# 預設管理員帳密（由 seed / 啟動時建立）；正式環境務必覆蓋。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# --- 檔案上傳 / 估價（Phase 5）---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
ALLOWED_FILE_FORMATS=stl,obj,step,stp
MAX_PRINT_DIMENSION_MM=300
